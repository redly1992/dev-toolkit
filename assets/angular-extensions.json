{
  "build": {
    "focus": {
      "sourceMap": true,
      "optimization": false,
      "assets": [
        "src/favicon.svg",
        {
          "glob": "**/*",
          "input": "src/assets/",
          "ignore": [
            "**/*.scss"
          ],
          "output": "/assets/"
        },
        "src/authentication.configuration.json"
      ],
      "fileReplacements": [
        {
          "replace": "src/app/app-routing.config.ts",
          "with": "dev-toolkit/assets/app-routing.focus.config.ts"
        }
      ]
    }
  },
  "serve": {
    "focus": {
      "buildTarget": "topicus:build:focus"
    }
  },
